# TransitWind Configuration
SECRET_KEY=change-me-to-a-random-string
GEMINI_API_KEY=your-gemini-api-key
DATABASE_URL=sqlite:///./transitwind.db

# Optional: Swiss Ephemeris data path (defaults to bundled)
# EPHE_PATH=/path/to/ephe

# Seed user (auto-created on first startup if set)
# SEED_USER_EMAIL=you@example.com
# SEED_USER_PASSWORD=your-password
# SEED_USER_NAME=Your Name
# SEED_BIRTH_DATETIME=1990-01-01T12:00:00Z
# SEED_BIRTH_LOCATION=City, State, Country
# SEED_BIRTH_LAT=0.0
# SEED_BIRTH_LON=0.0
